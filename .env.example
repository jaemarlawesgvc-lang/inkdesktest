# ══════════════════════════════════════════════════════════════════════════════
#  InkDesk — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
#  See the Deployment Guide (Phase 23) for per-service setup instructions.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
#  Found at: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://fgdjxwjiaxmooonbybqe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_HXAYCCl6PVgZ1QbhoOYhaQ_OjywyJQh
SUPABASE_SERVICE_ROLE_KEY=sb_secret_VMvqP0l-KPVrQ7n6H4X4jg_XaMFZWo5

# ── Stripe (Platform Keys) ────────────────────────────────────────────────────
#  Found at: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Product Price IDs
#  Create products in the Stripe Dashboard first, then paste the price IDs here.
#  Pro Plan:    £19/month
#  Studio Plan: £49/month
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...

# Stripe Connect (for artist payouts — Destination Charges model)
#  Found at: dashboard.stripe.com → Connect → Settings → Client ID
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Google Gemini (AI Site Generation) ───────────────────────────────────────
#  Found at: aistudio.google.com → API Keys
GEMINI_API_KEY=AQ.Ab8RN6IpkWWNdeos8i6TlsR4c76r13zlYZ3woqgZqs-0WOO64Q

# ── Resend (Transactional Email) ──────────────────────────────────────────────
#  Found at: resend.com → API Keys
#  Domain must be verified before RESEND_FROM_EMAIL will work in production.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@inkdesk.co

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
#  Found at: console.upstash.com → Your Database → REST API
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Sentry (Error Monitoring) — OPTIONAL ─────────────────────────────────────
#  InkDesk boots and runs normally without these values.
#  Safe to leave blank in local development.
#  Found at: sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=inkdesk
SENTRY_AUTH_TOKEN=your-sentry-auth-token-for-source-maps

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=InkDesk

# Cron job authentication secret.
# Must be at least 32 characters. Used to authenticate POST requests to /api/cron/*.
# Generate a secure value with: openssl rand -hex 32
CRON_SECRET=replace-with-openssl-rand-hex-32-output
